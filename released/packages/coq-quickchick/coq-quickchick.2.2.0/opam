  "ocaml" {>= "4.07"}
  "menhir" {build}
  "cppo" {build & >= "1.6.8"}
  "coq" {>= "8.15~"}
  "coq-ext-lib"
  "coq-mathcomp-ssreflect"
  "coq-simple-io" {>= "1.6.0"}
  "ocamlfind"
  "ocamlbuild"
